# Asegurar que los archivos batch de Windows siempre se extraigan con saltos de línea CRLF
*.bat text eol=crlf

# Asegurar que los scripts de bash siempre se extraigan con saltos de línea LF
*.sh text eol=lf
*.cjs text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
nginx.conf text eol=lf
.dockerignore text eol=lf
